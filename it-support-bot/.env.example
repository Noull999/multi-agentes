# === Configuración LLM ===

# Opción A: OpenCode Go (tu suscripción actual — RECOMENDADO)
# Modelos: glm-5, deepseek-v4-flash, kimi-k2.6
# Uso: python main.py "PC no enciende" --opencode
# Uso con modelo específico: python main.py "..." --opencode --model kimi-k2.6
OPENCODE_API_KEY=tu_key_aqui
OPENCODE_MODEL=glm-5
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Opción B: Gemini (gratis, sin tarjeta)
# Uso: python main.py "PC no enciende" --gemini
# GEMINI_API_KEY=AIzaSy...

# Opción C: OpenAI (pago)
# Uso: python main.py "PC no enciende" --openai-key sk-...
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_NAME=gpt-4o
