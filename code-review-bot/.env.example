# === Configuracion LLM ===

# Opcion A: OpenCode Go (tu suscripcion actual — RECOMENDADO)
# Modelos: glm-5, deepseek-v4-flash, kimi-k2.6
# Uso: python main.py /ruta/proyecto --opencode
# Uso con modelo especifico: python main.py /ruta/proyecto --opencode --model deepseek-v4-flash
OPENCODE_API_KEY=tu_key_aqui
OPENCODE_MODEL=glm-5
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Opcion B: Gemini (gratis, sin tarjeta)
# Uso: python main.py /ruta/proyecto --gemini
# GEMINI_API_KEY=AIzaSy...

# Opcion C: OpenAI (pago)
# Uso: python main.py /ruta/proyecto --openai-key sk-...
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_NAME=gpt-4o
# OPENAI_API_BASE_URL=https://api.openai.com/v1
