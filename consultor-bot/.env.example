# === Configuracion LLM ===

# Opcion A: OpenCode Go (tu suscripcion actual — RECOMENDADO)
# Modelos disponibles: glm-5, deepseek-v4-flash, kimi-k2.6
# Uso: python main.py --input "..." (lee OPENCODE_API_KEY automaticamente)
OPENCODE_API_KEY=tu_key_aqui
OPENCODE_MODEL=glm-5
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Opcion B: Gemini (gratis, sin tarjeta)
# Consigue key: https://aistudio.google.com/apikey
# Uso: configurar en run_crew con LLM(model="openai/gemini-2.5-pro", ...)
# GEMINI_API_KEY=AIzaSy...

# Opcion C: OpenAI (pago)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_NAME=gpt-4o-mini
