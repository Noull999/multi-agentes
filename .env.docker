# ==========================================
# Docker Compose - Variables de entorno
# ==========================================
# Copia este archivo como .env y completa:
# cp .env.docker .env

# Obligatorio - Tu API key de OpenCode Go
OPENCODE_API_KEY=sk-tu-key-aqui

# API Key para proteger los endpoints REST (deja vacío para acceso público)
API_KEY=

# Opcionales - Alternativas
GEMINI_API_KEY=
OPENAI_API_KEY=

# Brave Search API — 2000 búsquedas/mes gratis (https://api.search.brave.com)
# Si se configura, el IT Support Bot buscará en Brave además de DDG/Wikipedia/StackExchange
BRAVE_API_KEY=
